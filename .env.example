# Fish Audio API key. Required.
# In NixOS dev shell: source this file, or use direnv.
# On dellan (system-installed): supplied via agenix at
#   $(cat $(systemctl show-environment | grep FISH_AUDIO_API_KEY_FILE))
# and read from FISH_AUDIO_API_KEY_FILE by the wrapper.
FISH_AUDIO_API_KEY=

# Alternative: point at a file containing the key (mode 0400).
# Wrapper on dellan sets this to config.age.secrets.fish-audio-api-key.path.
# FISH_AUDIO_API_KEY_FILE=

# Optional. SDK default is "s2-pro". Other valid: "s1".
# FISH_AUDIO_MODEL=s2-pro

# Optional. Fish voice library reference_id; unset = SDK default voice.
# FISH_AUDIO_VOICE_ID=

# Optional. Prosody speed, 0.8 to 1.2.
# LISTEN_SPEED=1.0

# Optional. Override cache dir (default: platformdirs user cache / "tts-tool").
# LISTEN_CACHE_DIR=
